# =============================================================================
# ExpenseFlow Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local or any file with real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (required)
# Get these from: https://app.supabase.com → Project Settings → API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Supabase project ref (used by supabase CLI)
SUPABASE_PROJECT_REF=your-project-ref

# -----------------------------------------------------------------------------
# AI Providers (free tiers available)
# -----------------------------------------------------------------------------

# Google Gemini — https://aistudio.google.com/app/apikey (free tier)
GEMINI_API_KEY=your-gemini-api-key

# Groq (Llama 3, Mixtral) — https://console.groq.com/keys (free tier)
GROQ_API_KEY=your-groq-api-key

# -----------------------------------------------------------------------------
# Currency Exchange Rates
# Open Exchange Rates — https://openexchangerates.org (free tier: 1000 req/mo)
# -----------------------------------------------------------------------------
OPEN_EXCHANGE_RATES_APP_ID=your-app-id

# -----------------------------------------------------------------------------
# Expo / React Native (mobile)
# -----------------------------------------------------------------------------

# Public Supabase vars for Expo (mirrors NEXT_PUBLIC_* for mobile)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Expo project ID — https://expo.dev → Project → Settings
EXPO_PUBLIC_PROJECT_ID=your-expo-project-id

# EAS build token — https://expo.dev → Account Settings → Access Tokens
EXPO_TOKEN=your-expo-token

# -----------------------------------------------------------------------------
# Web Application
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://expense-reducer.vercel.app
NEXT_PUBLIC_APP_NAME=ExpenseFlow

# -----------------------------------------------------------------------------
# Google OAuth (configured in Supabase dashboard, not needed in .env directly)
# Supabase handles the OAuth redirect — just add your domain in Supabase Auth settings.
# Uncomment if you handle OAuth outside of Supabase:
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Optional: Razorpay (Indian payment gateway)
# https://dashboard.razorpay.com/app/keys
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxx
# RAZORPAY_KEY_SECRET=your-razorpay-secret

# -----------------------------------------------------------------------------
# Optional: Slack alerts for budget / anomaly notifications
# https://api.slack.com/apps → Incoming Webhooks
# -----------------------------------------------------------------------------
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# -----------------------------------------------------------------------------
# Optional: Sentry error tracking
# https://sentry.io → Project → Settings → Client Keys
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/yyy
# SENTRY_AUTH_TOKEN=your-sentry-auth-token
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug

# -----------------------------------------------------------------------------
# Phase 11-14: Integrations
# -----------------------------------------------------------------------------

# Google Sheets — export expenses to spreadsheets
# https://console.cloud.google.com/apis/credentials
# GOOGLE_SHEETS_CLIENT_ID=your-google-sheets-client-id
# GOOGLE_SHEETS_CLIENT_SECRET=your-google-sheets-client-secret

# Plaid — bank account linking & transaction import
# https://dashboard.plaid.com/developers/keys
# PLAID_CLIENT_ID=your-plaid-client-id
# PLAID_SECRET=your-plaid-secret

# Salt Edge — open-banking aggregation (alternative to Plaid)
# https://www.saltedge.com/dashboard
# SALT_EDGE_APP_ID=your-salt-edge-app-id
# SALT_EDGE_SECRET=your-salt-edge-secret

# Slack — webhook for budget alerts & anomaly notifications
# https://api.slack.com/apps -> Incoming Webhooks
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# -----------------------------------------------------------------------------
# Development only
# -----------------------------------------------------------------------------
# NODE_ENV=development
