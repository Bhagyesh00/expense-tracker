# =============================================================================
# pnpm configuration for the ExpenseFlow monorepo
# =============================================================================

# Hoist all packages to the root node_modules so tools like Next.js and
# Metro bundler (Expo) can resolve transitive dependencies reliably.
shamefully-hoist=true

# Do not fail on peer dependency conflicts — many React Native / Expo packages
# declare peer deps that are met indirectly.
strict-peer-dependencies=false

# Automatically install missing peer dependencies.
auto-install-peers=true

# Prefer symlinks for workspace packages to keep build times fast.
prefer-symlinked-executables=true

# Store path — let pnpm choose the default (~/.pnpm-store) so CI cache
# helpers can locate it via `pnpm store path`.
# store-dir=~/.pnpm-store

# Lockfile behaviour
frozen-lockfile=false

# Avoid writing to node_modules/.modules.yaml on every install (speeds up CI).
# modules-cache-max-age=10080

# Package resolution
resolve-peers-from-workspace-root=true
